{
	"name": "tech-to-customer",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "concurrently -k \"pnpm run dev:frontend\" \"pnpm run dev:backend\"",
		"dev:frontend": "next dev",
		"dev:backend": "tsx services/server.ts",
		"build": "pnpm run build:frontend && pnpm run build:backend",
		"build:frontend": "pnpm exec next build",
		"build:format": "node -e \"const {execSync}=require('child_process');try{execSync('pnpm exec prettier . --check',{stdio:'inherit'});}catch(e){execSync('pnpm exec prettier . --write',{stdio:'inherit'});}\"",
		"format:check": "pnpm exec prettier . --check",
		"build:backend": "tsc -p tsconfig.backend.json",
		"start": "next start",
		"test": "jest --runInBand",
		"format": "pnpm exec prettier . --write",
		"lint": "eslint . -f  ./eslint.formatter.js && pnpm exec prettier . --check",
		"lint:no-format": "eslint .",
		"lint:auto-format": "eslint . -f ./eslint.formatter.js --fix && node -e \"const {execSync}=require('child_process');try{execSync('pnpm exec prettier . --check',{stdio:'inherit'});}catch(e){execSync('pnpm exec prettier . --write',{stdio:'inherit'});}\"",
		"migrate:status": "node db/migrations/scripts/migrate.js status",
		"migrate:up": "node db/migrations/scripts/migrate.js up",
		"migrate:down": "node db/migrations/scripts/migrate.js down",
		"migrate:create": "node db/migrations/scripts/create-migration.js",
		"seed:demo": "tsx scripts/seed-demo.ts",
		"seed:demo:reset": "tsx scripts/seed-demo.ts --reset",
		"init:workspace": "node scripts/init-workspace.mjs",
		"prepare": "husky"
	},
	"dependencies": {
		"@fastify/cors": "^11.2.0",
		"@fastify/formbody": "^8.0.2",
		"@fastify/jwt": "^10.0.0",
		"@googlemaps/js-api-loader": "^2.0.2",
		"@neondatabase/serverless": "^1.0.2",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.6.0",
		"@tanstack/react-query": "^5.99.0",
		"@types/three": "^0.183.1",
		"@vis.gl/react-google-maps": "^1.8.3",
		"bcryptjs": "^3.0.3",
		"clsx": "^2.1.1",
		"concurrently": "^9.2.1",
		"date-fns": "^4.1.0",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"fastify": "^5.8.5",
		"fastify-raw-body": "^5.0.0",
		"framer-motion": "^12.38.0",
		"intuit-oauth": "^4.2.3",
		"jsonwebtoken": "^9.0.3",
		"leva": "^0.10.1",
		"lucide-react": "^0.563.0",
		"next": "16.2.3",
		"node-quickbooks": "^2.0.50",
		"pg": "^8.20.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"prettier": "^3.8.2",
		"prom-client": "^15.1.3",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"regression": "^2.0.1",
		"stripe": "^20.3.1",
		"tailwind-merge": "^3.5.0",
		"three": "^0.183.2",
		"undici": "^8.1.0",
		"ws": "^8.20.0",
		"zod": "^4.3.6",
		"zustand": "^4.5.5"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@tailwindcss/postcss": "^4.2.4",
		"@types/google.maps": "^3.58.1",
		"@types/jest": "^30.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.6.0",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/regression": "^2.0.6",
		"@types/ws": "^8.18.1",
		"babel-jest": "^30.3.0",
		"eslint": "^9.39.4",
		"eslint-config-next": "^16.2.3",
		"husky": "^9.1.7",
		"jest": "^30.3.0",
		"jest-environment-node": "^30.3.0",
		"node-pg-migrate": "^8.0.4",
		"tailwindcss": "^4.2.2",
		"ts-jest": "^29.4.9",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}

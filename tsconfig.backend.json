{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"allowImportingTsExtensions": false,
		"noEmit": false,
		"outDir": "./dist"
	},
	"include": [
		"services/**/*",
		"db/**/*",
		"db.ts",
		"algo/**/*",
		"dispatch/**/*",
		"cron/**/*",
		"rateLimit.ts",
		"verifyCrypto.ts",
		"middleware/**/*",
		"utils/**/*"
	],
	"exclude": [
		"node_modules",
		"services/logging/**",
		"services/routes/loggingRoutes.ts"
	]
}
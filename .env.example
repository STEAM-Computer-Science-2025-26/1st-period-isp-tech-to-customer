# This is an example env file. Copy this to a .env.local file in the root
# After you copy make sure all of the variables are set correctly and make sure .env.local is in your .gitignore

DATABASE_URL=postgresql://neondb_owner:

# ─── Dev Tools ────────────────────────────────────────────────────────────────
# Set to "true" to enable the /dev route, the Developer Tools sidebar item,
# and the Fastify /dev/db/* endpoints. Leave unset or set to "false" in prod.
NEXT_PUBLIC_ENABLE_DEV_TOOLS=true